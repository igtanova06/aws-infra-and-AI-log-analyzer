# ============================================================
# Terraform Variables for Dev Environment
# Copy this file to terraform.tfvars and customize
# ============================================================

# Project Configuration
project       = "p1"
env           = "dev"
region_short  = "apse1"

# Network Configuration
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]
db_subnet_cidrs      = ["10.0.7.0/24", "10.0.8.0/24", "10.0.9.0/24"]

# NAT Gateway (set to true if you need internet access from private subnets)
# WARNING: NAT Gateway costs ~$32/month per gateway
enable_nat_gateway = false

# Database Configuration
db_username = "admin"

# Tags (optional - merged with default tags)
tags = {
  Owner       = "team-devops"
  CostCenter  = "engineering"
  Compliance  = "none"
}
